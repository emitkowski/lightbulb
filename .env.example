# ----------------------------------------------------------
# Per-project — change these for every new app
# ----------------------------------------------------------
APP_NAME=lightbulb
APP_URL=https://lightbulb.test
APP_DOMAIN=lightbulb.test

# Sail — set to your local UID/GID (run: id)
WWWUSER=1000
WWWGROUP=1000

# Sail ports — must be unique across all running projects
VITE_PORT=5177
REVERB_PORT=8082

# ----------------------------------------------------------
APP_ENV=local
APP_KEY=
APP_DEBUG=true

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=lightbulb
DB_USERNAME=root
DB_PASSWORD=password

SESSION_DRIVER=database
SESSION_LIFETIME=1440
SESSION_ENCRYPT=false          # set true in production
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false    # set true in production (HTTPS only)

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT="${REVERB_PORT}"
REVERB_CLIENT_HOST=reverb
REVERB_SCHEME=http

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Signal ingestion
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=Lightbulb/1.0
# Optional — unauthenticated GitHub API allows 60 req/hr; a token raises it to 5,000/hr
GITHUB_TOKEN=
# Optional — unauthenticated StackExchange API allows 300 req/day; a key raises it to 10,000/day
STACKEXCHANGE_KEY=
# Required for Product Hunt ingestion — get a free key at producthunt.com/v2/oauth/applications
PRODUCTHUNT_API_KEY=
# Required for Twitter/X ingestion — App-only Bearer Token from developer.twitter.com (v2 API)
TWITTER_BEARER_TOKEN=
# Required for Apify-based ingestion (G2, AppSumo, Chrome Web Store, Gumroad, Freelance, PeoplePerHour, Guru, Indeed, LinkedIn)
APIFY_TOKEN=
# Optional — override default Apify actor IDs if you prefer a different scraper
# APIFY_G2_ACTOR=memo23/g2-scraper
# APIFY_APPSUMO_ACTOR=easyapi/appsumo-product-scraper  # BROKEN — times out (likely bot-protected), see docs/BUGS.md
# APIFY_CHROME_ACTOR=vujeen/chrome-web-store-scraper
# APIFY_GUMROAD_ACTOR=muhammetakkurtt/gumroad-scraper
# APIFY_UPWORK_ACTOR=getdataforme/upwork-actor
# APIFY_PEOPLEPERHOUR_ACTOR=getdataforme/peopleperhour-job-scraper
# APIFY_GURU_ACTOR=getdataforme/guru-jobs-scraper
# APIFY_INDEED_ACTOR=misceres/indeed-scraper
# APIFY_LINKEDIN_ACTOR=curious_coder/linkedin-jobs-scraper

# Scoring pipeline
# SCORING_DRIVER: 'cli' (default) uses the Claude Code CLI; 'api' uses the Anthropic API directly
SCORING_DRIVER=cli

# Claude CLI driver (SCORING_DRIVER=cli)
# Set CLAUDE_CLI_PATH to the absolute path of the claude binary.
# Inside a Sail container the host PATH is not available — run scoring on the host
# (php artisan scoring:run) or install claude inside the container.
CLAUDE_CLI_PATH=claude
CLAUDE_USE_CLI_AUTH=true
CLAUDE_HOME=/home/eric
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_CLI_TIMEOUT=120

# Anthropic API driver (SCORING_DRIVER=api)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
SERPER_API_KEY=
